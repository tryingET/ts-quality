{
  "name": "ts-quality-workspace",
  "version": "0.1.4",
  "private": true,
  "description": "ts-quality alpha - evidence, judgment, understanding, governance, legitimacy for TypeScript changes",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "ts-quality": "dist/packages/ts-quality/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:scripts": "tsc -p tsconfig.scripts-check.json",
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/run-tests.mjs",
    "sample-artifacts": "node scripts/generate-samples.mjs",
    "smoke": "node scripts/smoke.mjs",
    "smoke:packaging": "node scripts/packaging-smoke.mjs",
    "witness:refresh": "node dist/packages/ts-quality/src/cli.js witness refresh",
    "check:with-witnesses": "npm run witness:refresh --silent && node dist/packages/ts-quality/src/cli.js check",
    "verify": "node scripts/verify.mjs",
    "verify:artifacts:check": "node scripts/verify.mjs --skip-install --check-artifacts",
    "verify:ci": "npm run verify:artifacts:check",
    "handoff:sync": "node scripts/handoff-sync.mjs",
    "handoff:check": "node scripts/handoff-sync.mjs --check",
    "clean": "node scripts/clean.mjs",
    "release:plan": "node scripts/release-orchestrator.mjs plan",
    "release:prepare": "node scripts/release-orchestrator.mjs prepare",
    "release:github": "node scripts/release-orchestrator.mjs github",
    "release:verify-public": "node scripts/release-orchestrator.mjs verify-public",
    "release:intent:check": "node scripts/validate-release-intent.mjs",
    "pack:ts-quality": "node scripts/pack-ts-quality.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  }
}
